# ============================================================================
# Snappy Gift — Environment variables
# ============================================================================
# Эти переменные автоматически генерируются Lovable Cloud и доступны в .env
# Файл предоставлен как справочник структуры.
# ============================================================================

# URL вашего Supabase проекта
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Publishable (anon) ключ — безопасно хранить в клиенте
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...

# Project ID для построения URL edge functions
VITE_SUPABASE_PROJECT_ID=<project-ref>

# ============================================================================
# Серверные секреты (доступны ТОЛЬКО в edge functions, НЕ в клиенте)
# Устанавливаются через UI Lovable Cloud → Secrets
# ============================================================================

# LOVABLE_API_KEY           — ключ для Lovable AI Gateway (auto-provisioned)
# SUPABASE_SERVICE_ROLE_KEY — service-role ключ (auto-provisioned)
# SUPABASE_DB_URL           — прямое подключение к Postgres (auto-provisioned)